{
  "name": "@neovici/cosmoz-bottom-bar",
  "version": "11.1.1",
  "description": "A responsive bottom-bar that can house buttons/actions and a menu for the buttons that won't fit the available width.",
  "keywords": [
    "polymer",
    "web-components"
  ],
  "homepage": "https://github.com/Neovici/cosmoz-bottom-bar#readme",
  "bugs": {
    "url": "https://github.com/Neovici/cosmoz-bottom-bar/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Neovici/cosmoz-bottom-bar.git"
  },
  "license": "Apache-2.0",
  "author": "Neovici Development",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist/*",
    "types"
  ],
  "scripts": {
    "lint": "tsc && eslint --cache .",
    "build": "tsc -p tsconfig.build.json",
    "changeset": "changeset",
    "check:duplicates": "check-duplicate-components",
    "start": "npm run storybook:start",
    "test": "wtr --coverage",
    "test:watch": "wtr --watch",
    "prepare": "husky",
    "storybook:start": "storybook dev -p 8000",
    "storybook:build": "storybook build",
    "storybook:deploy": "storybook-to-ghpages",
    "storybook:preview": "npm run storybook:build && http-server -d ./storybook-static/"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@neovici/cosmoz-button": "^1.1.1",
    "@neovici/cosmoz-collapse": "^1.5.0",
    "@neovici/cosmoz-dropdown": "^7.7.2-beta.1",
    "@neovici/cosmoz-icons": "^1.6.0",
    "@neovici/cosmoz-tokens": "^3.5.0",
    "@neovici/cosmoz-utils": "^6.13.1",
    "@pionjs/pion": "^2.5.2",
    "@polymer/polymer": "^3.3.0",
    "lit-html": "^2.0.0 || ^3.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.28.0",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@neovici/cfg": "^2.8.0",
    "@open-wc/testing": "^4.0.0",
    "@storybook/web-components-vite": "^10.1.11",
    "@types/mocha": "^10.0.6",
    "@webcomponents/webcomponentsjs": "^2.5.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.0.0",
    "eslint-plugin-storybook": "10.5.0",
    "http-server": "^14.1.1",
    "husky": "^9.1.1",
    "lint-staged": "^17.0.4",
    "rollup-plugin-esbuild": "^6.1.1",
    "sinon": "^22.0.0",
    "storybook": "^10.1.11",
    "typescript": "^6.0.3"
  }
}
